<Window x:Class="CybersecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureNet — Cybersecurity Assistant"
        Height="700" Width="1000"
        MinHeight="600" MinWidth="850"
        Background="#0D1117"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="TopicButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,1,0">
            <StackPanel>

                <!-- ASCII Art + Logo -->
                <Border Background="#0D1117" Padding="8,12" BorderBrush="#21262D" BorderThickness="0,0,0,1">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text=" ___  ___  ___ " FontFamily="Cascadia Mono, Consolas" FontSize="8" Foreground="#00D4FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="/ __||  _|| __|" FontFamily="Cascadia Mono, Consolas" FontSize="8" Foreground="#00D4FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="\__ \| |_ | _| " FontFamily="Cascadia Mono, Consolas" FontSize="8" Foreground="#00D4FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="|___/|___||___|" FontFamily="Cascadia Mono, Consolas" FontSize="8" Foreground="#00D4FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="🛡️" FontSize="22" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="SECURENET" FontFamily="Cascadia Mono, Consolas" FontSize="11" FontWeight="Bold" Foreground="#00D4FF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        <TextBlock Text="Cybersecurity Assistant" FontFamily="Segoe UI" FontSize="9" Foreground="#8B949E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <TextBlock Text="NAVIGATION" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#8B949E" Margin="16,12,0,4"/>
                <Button Content="💬  Chat" Click="NavChat_Click" Style="{StaticResource NavButtonStyle}" Margin="8,2"/>
                <Button Content="✅  Task Manager" Click="NavTasks_Click" Style="{StaticResource NavButtonStyle}" Margin="8,2"/>
                <Button Content="🎮  Quiz" Click="NavQuiz_Click" Style="{StaticResource NavButtonStyle}" Margin="8,2"/>

                <!-- Topics -->
                <TextBlock Text="TOPICS" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#8B949E" Margin="16,12,0,4"/>
                <Button Content="1. Passwords" Tag="password" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="2. Phishing" Tag="phishing" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="3. Privacy" Tag="privacy" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="4. Malware" Tag="malware" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="5. Scams" Tag="scam" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="6. Firewall" Tag="firewall" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="7. Encryption" Tag="encryption" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="8. 2FA" Tag="2fa" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="9. Backups" Tag="backup" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>
                <Button Content="10. VPN" Tag="vpn" Click="TopicButton_Click" Style="{StaticResource TopicButtonStyle}"/>

            </StackPanel>
        </Border>

        <!-- RIGHT CONTENT AREA -->
        <Grid Grid.Column="1">

            <!-- CHAT PANEL -->
            <Grid x:Name="ChatPanel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#3FB950" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="SecureNet" FontFamily="Segoe UI" FontSize="15" FontWeight="Bold" Foreground="#E6EDF3"/>
                        <TextBlock Text=" is online" FontFamily="Segoe UI" FontSize="12" Foreground="#3FB950" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#0D1117" Padding="12,8">
                    <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ChatMessages" Margin="0,4"/>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserInput" Grid.Column="0" Height="42" FontSize="14" FontFamily="Segoe UI"
                                 Foreground="White" Background="#2D333B" CaretBrush="White"
                                 BorderBrush="#00D4FF" BorderThickness="1" Padding="12,8"
                                 VerticalContentAlignment="Center" KeyDown="UserInput_KeyDown"/>
                        <Button Grid.Column="2" Content="Send ➤" Height="42" Width="85"
                                FontSize="13" FontWeight="Bold" Foreground="#0D1117"
                                Background="#00D4FF" BorderThickness="0" Cursor="Hand"
                                Click="SendButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#010409" BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="12,4">
                    <TextBlock x:Name="StatusBar" Text="SecureNet ready!" FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"/>
                </Border>
            </Grid>

            <!-- TASK PANEL -->
            <Grid x:Name="TaskPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,12">
                    <TextBlock Text="✅ Task Manager" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="#E6EDF3"/>
                </Border>

                <Border Grid.Row="1" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="ADD NEW TASK" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TaskTitleInput" Grid.Column="0" Height="36" FontSize="13"
                                     Foreground="White" Background="#2D333B" CaretBrush="White"
                                     BorderBrush="#30363D" BorderThickness="1" Padding="10,6" ToolTip="Task title"/>
                            <TextBox x:Name="TaskDescInput" Grid.Column="2" Height="36" FontSize="13"
                                     Foreground="White" Background="#2D333B" CaretBrush="White"
                                     BorderBrush="#30363D" BorderThickness="1" Padding="10,6" ToolTip="Description"/>
                            <TextBox x:Name="TaskReminderInput" Grid.Column="4" Height="36" FontSize="13"
                                     Foreground="White" Background="#2D333B" CaretBrush="White"
                                     BorderBrush="#30363D" BorderThickness="1" Padding="10,6" ToolTip="Reminder (e.g. In 3 days)"/>
                            <Button Grid.Column="6" Content="+ Add Task" Height="36" Padding="16,0"
                                    FontSize="13" FontWeight="Bold" Foreground="#0D1117"
                                    Background="#00D4FF" BorderThickness="0" Cursor="Hand"
                                    Click="AddTaskButton_Click"/>
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Title *" FontSize="10" Foreground="#8B949E"/>
                            <TextBlock Grid.Column="2" Text="Description" FontSize="10" Foreground="#8B949E"/>
                            <TextBlock Grid.Column="4" Text="Reminder (optional)" FontSize="10" Foreground="#8B949E"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#0D1117" Padding="16,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="YOUR TASKS" FontFamily="Segoe UI" FontSize="10" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,0,8"/>
                        <ListBox x:Name="TaskListBox" Grid.Row="1" Background="#161B22" BorderBrush="#21262D"
                                 BorderThickness="1" Foreground="White" FontFamily="Segoe UI"
                                 FontSize="13" Padding="4" SelectionMode="Single"/>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="✅ Mark Complete" Height="36" Padding="16,0" FontSize="13" FontWeight="Bold"
                                Foreground="White" Background="#3FB950" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,8,0" Click="MarkCompleteButton_Click"/>
                        <Button Content="🗑️ Delete Task" Height="36" Padding="16,0" FontSize="13" FontWeight="Bold"
                                Foreground="White" Background="#F85149" BorderThickness="0" Cursor="Hand"
                                Click="DeleteTaskButton_Click"/>
                        <TextBlock x:Name="TaskStatusLabel" FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#8B949E" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- QUIZ PANEL -->
            <Grid x:Name="QuizPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🎮 Cybersecurity Quiz" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="#E6EDF3"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock x:Name="QuizScoreLabel" Text="Score: 0" FontFamily="Segoe UI" FontSize="13"
                                       Foreground="#00D4FF" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock x:Name="QuizProgressLabel" Text="Question 1 of 12" FontFamily="Segoe UI"
                                       FontSize="13" Foreground="#8B949E" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#0D1117" Padding="24,20">
                    <StackPanel x:Name="QuizContent">

                        <!-- Start Screen -->
                        <StackPanel x:Name="QuizStartScreen" HorizontalAlignment="Center">
                            <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Cybersecurity Quiz" FontFamily="Segoe UI" FontSize="24"
                                       FontWeight="Bold" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                            <TextBlock Text="Test your cybersecurity knowledge with 12 questions!"
                                       FontFamily="Segoe UI" FontSize="14" Foreground="#8B949E"
                                       HorizontalAlignment="Center" Margin="0,8,0,24"/>
                            <Button Content="▶ Start Quiz" Height="44" Width="160" FontSize="15" FontWeight="Bold"
                                    Foreground="#0D1117" Background="#00D4FF" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Center" Click="StartQuizButton_Click"/>
                        </StackPanel>

                        <!-- Question Screen -->
                        <StackPanel x:Name="QuizQuestionScreen" Visibility="Collapsed">
                            <TextBlock x:Name="QuizQuestionText" FontFamily="Segoe UI" FontSize="16"
                                       FontWeight="Bold" Foreground="#E6EDF3" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            <StackPanel x:Name="QuizOptionsPanel" Margin="0,0,0,16"/>
                            <Button x:Name="SubmitAnswerButton" Content="Submit Answer" Height="40" Width="160"
                                    FontSize="13" FontWeight="Bold" Foreground="#0D1117" Background="#00D4FF"
                                    BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                                    Click="SubmitAnswerButton_Click"/>
                            <Border x:Name="FeedbackBorder" Background="#161B22" BorderBrush="#21262D"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12"
                                    Margin="0,16,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock x:Name="FeedbackText" FontFamily="Segoe UI" FontSize="14"
                                               Foreground="#E6EDF3" TextWrapping="Wrap"/>
                                    <Button x:Name="NextQuestionButton" Content="Next Question ➤" Height="36" Width="160"
                                            FontSize="13" FontWeight="Bold" Foreground="#0D1117" Background="#3FB950"
                                            BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                                            Margin="0,12,0,0" Click="NextQuestionButton_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Results Screen -->
                        <StackPanel x:Name="QuizResultsScreen" Visibility="Collapsed" HorizontalAlignment="Center">
                            <TextBlock Text="🏆" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock x:Name="QuizFinalMessage" FontFamily="Segoe UI" FontSize="18"
                                       FontWeight="Bold" Foreground="#E6EDF3" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,0,0,24"/>
                            <Button Content="🔄 Play Again" Height="44" Width="160" FontSize="15" FontWeight="Bold"
                                    Foreground="#0D1117" Background="#00D4FF" BorderThickness="0" Cursor="Hand"
                                    HorizontalAlignment="Center" Click="StartQuizButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,1,0,0" Padding="16,8">
                    <TextBlock x:Name="QuizStatusBar" Text="Click Start Quiz to begin!"
                               FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"/>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>